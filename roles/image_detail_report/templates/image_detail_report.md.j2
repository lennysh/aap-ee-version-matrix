  Use default(..., true) for fields that may be explicitly null after inspection.
-#}
{%- macro render_collections_table(items) -%}
{%- set safe_items = items | default([], true) -%}
{%- if safe_items | length > 0 -%}
| Collection | Version |
|---|---|
{% for entry in safe_items | sort -%}
{%- set parts = entry.split(' ', 1) -%}
| `{{ parts[0] }}` | {{ parts[1] if parts | length > 1 else 'N/A' }} |
{% endfor -%}
{%- else -%}
*None*
{%- endif -%}
{%- endmacro -%}

{%- macro render_rpm_table(items) -%}
{%- set safe_items = items | default([], true) -%}
{%- if safe_items | length > 0 -%}
| Package | Version-Release |
|---|---|
{% for entry in safe_items | sort -%}
{%- set parts = entry.rsplit(' ', 1) -%}
| `{{ parts[0] }}` | {{ parts[1] if parts | length > 1 else 'N/A' }} |
{% endfor -%}
{%- else -%}
*None*
{%- endif -%}
{%- endmacro -%}

{%- macro render_pip_table(items) -%}
{%- set safe_items = items | default([], true) -%}
{%- if safe_items | length > 0 -%}
| Package | Version |
|---|---|
{% for entry in safe_items | sort -%}
{%- set parts = entry.split('==', 1) -%}
| `{{ parts[0] }}` | {{ parts[1] if parts | length > 1 else 'N/A' }} |
{% endfor -%}
{%- else -%}
*None*
{%- endif -%}
{%- endmacro -%}

