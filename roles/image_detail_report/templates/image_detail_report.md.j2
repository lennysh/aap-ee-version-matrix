{# Group images by Ansible Core major.minor (same grouping as md_generator) #}
{%- set grouped_images = {} %}
{%- for image in images %}
  {%- set core_version = image.ansible_core_version | default('unknown', true) | string %}
  {%- if core_version != 'unknown' and '.' in core_version %}
    {%- set version_group = core_version.split('.')[0:2] | join('.') %}
  {%- else %}
    {%- set version_group = core_version %}
  {%- endif %}
  {%- if version_group not in grouped_images %}
    {%- set _ = grouped_images.update({version_group: []}) %}
  {%- endif %}
  {%- set _ = grouped_images[version_group].append(image) %}
{%- endfor -%}

